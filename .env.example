# ─── Cerebras AI ─────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ─── Security ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:8080

# ─── Debug ───────────────────────────────────────────────────────────────────
DEBUG_MODE=false
